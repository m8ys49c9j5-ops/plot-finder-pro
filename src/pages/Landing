      <section id="how" style={{ padding: "7rem clamp(1rem, 5vw, 3rem)" }}>
        <div style={{ maxWidth: "1000px", margin: "0 auto" }}>
          <div style={{ textAlign: "center", marginBottom: "4rem" }}>
            <span style={{
              fontSize: "0.75rem", fontWeight: 700, letterSpacing: "0.15em",
              textTransform: "uppercase", color: "#1fcc7a", display: "block", marginBottom: "1rem"
            }}>Procesas</span>
            <h2 style={{
              fontFamily: "'Syne', sans-serif", fontWeight: 800,
              fontSize: "clamp(1.8rem, 4vw, 3rem)", color: "#e8edf5", letterSpacing: "-0.02em"
            }}>
              Trys žingsniai iki ataskaitos
            </h2>
          </div>
          <div style={{
            display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(280px, 1fr))", gap: "1.5rem"
          }}>
            {STEPS.map((s, i) => (
              <div key={i} style={{
                background: "#0b1221", border: "1px solid #1a2236",
                borderRadius: "20px", padding: "2rem", position: "relative", overflow: "hidden",
              }}>
                <div style={{
                  position: "absolute", top: "1.5rem", right: "1.5rem",
                  fontFamily: "'Unbounded', sans-serif", fontSize: "3rem", fontWeight: 900,
                  color: "#1fcc7a0d", lineHeight: 1,
                }}>{s.num}</div>
                <div style={{
                  width: "48px", height: "48px", borderRadius: "14px",
                  background: "#1fcc7a1a", border: "1px solid #1fcc7a33",
                  display: "flex", alignItems: "center", justifyContent: "center",
                  color: "#1fcc7a", marginBottom: "1.25rem",
                }}>{s.icon}</div>
                <h3 style={{
                  fontFamily: "'Syne', sans-serif", fontWeight: 700, fontSize: "1.1rem",
                  color: "#e8edf5", marginBottom: "0.75rem",
                }}>{s.title}</h3>
                <p style={{ color: "#5a6a80", lineHeight: 1.7, fontSize: "0.9rem" }}>{s.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ======== FEATURES ======== */}
      <section style={{ padding: "7rem clamp(1rem, 5vw, 3rem)", background: "#08111f", borderTop: "1px solid #1a2236" }}>
        <div style={{ maxWidth: "1100px", margin: "0 auto" }}>
          <div style={{ textAlign: "center", marginBottom: "4rem" }}>
            <span style={{
              fontSize: "0.75rem", fontWeight: 700, letterSpacing: "0.15em",
              textTransform: "uppercase", color: "#1fcc7a", display: "block", marginBottom: "1rem"
            }}>Ataskaita</span>
            <h2 style={{
              fontFamily: "'Syne', sans-serif", fontWeight: 800,
              fontSize: "clamp(1.8rem, 4vw, 3rem)", color: "#e8edf5", letterSpacing: "-0.02em",
              marginBottom: "1rem"
            }}>
              Viskas vienoje ataskaitoje
            </h2>
            <p style={{ color: "#5a6a80", maxWidth: "480px", margin: "0 auto", lineHeight: 1.7 }}>
              Surenkame duomenis iš kelių oficialių registrų ir pateikiame jums suprantamai
            </p>
          </div>
          <div style={{
            display: "grid",
            gridTemplateColumns: "repeat(auto-fill, minmax(240px, 1fr))",
            gap: "1rem",
          }}>
            {FEATURES.map((f, i) => (
              <FeatureCard key={i} {...f} />
            ))}
          </div>
        </div>
      </section>

      {/* ======== PRICING ======== */}
      <section id="pricing" style={{ padding: "7rem clamp(1rem, 5vw, 3rem)" }}>
        <div style={{ maxWidth: "900px", margin: "0 auto" }}>
          <div style={{ textAlign: "center", marginBottom: "4rem" }}>
            <span style={{
              fontSize: "0.75rem", fontWeight: 700, letterSpacing: "0.15em",
              textTransform: "uppercase", color: "#1fcc7a", display: "block", marginBottom: "1rem"
            }}>Kainos</span>
            <h2 style={{
              fontFamily: "'Syne', sans-serif", fontWeight: 800,
              fontSize: "clamp(1.8rem, 4vw, 3rem)", color: "#e8edf5", letterSpacing: "-0.02em",
              marginBottom: "1rem"
            }}>Mokate tik kai naudojate</h2>
            <p style={{ color: "#5a6a80", lineHeight: 1.7 }}>
              Jokių prenumeratų. Jokių mėnesinių mokesčių. Kreditai negalioja.
            </p>
          </div>
          <div style={{
            display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(250px, 1fr))", gap: "1.5rem",
            alignItems: "end",
          }}>
            {PRICING.map((p, i) => (
              <div key={i} className="pricing-card" style={{
                background: p.highlight ? "linear-gradient(145deg, #0f1e30, #0b1823)" : "#0b1221",
                border: p.highlight ? "1px solid #1fcc7a55" : "1px solid #1a2236",
                borderRadius: "20px",
                padding: p.highlight ? "2.5rem 2rem" : "2rem",
                position: "relative",
                boxShadow: p.highlight ? "0 0 40px #1fcc7a18" : "none",
              }}>
                {p.highlight && (
                  <div style={{
                    position: "absolute", top: "-14px", left: "50%", transform: "translateX(-50%)",
                    background: "#1fcc7a", color: "#06090f",
                    fontSize: "0.7rem", fontWeight: 800, letterSpacing: "0.1em",
                    textTransform: "uppercase", padding: "4px 14px", borderRadius: "999px",
                    whiteSpace: "nowrap",
                  }}>Populiariausias</div>
                )}
                {p.save && !p.highlight && (
                  <div style={{
                    position: "absolute", top: "-12px", right: "1.5rem",
                    background: "#1fcc7a22", color: "#1fcc7a", border: "1px solid #1fcc7a44",
                    fontSize: "0.68rem", fontWeight: 700, letterSpacing: "0.08em",
                    textTransform: "uppercase", padding: "3px 10px", borderRadius: "999px",
                  }}>{p.save}</div>
                )}
                <h3 style={{
                  fontFamily: "'Syne', sans-serif", fontWeight: 700, fontSize: "1rem",
                  color: "#e8edf5", marginBottom: "0.5rem"
                }}>{p.name}</h3>
                <p style={{ color: "#5a6a80", fontSize: "0.85rem", marginBottom: "1.5rem" }}>
                  {p.credits} {p.credits === 1 ? "paieška" : "paieškų"}
                </p>
                <div style={{
                  fontFamily: "'Unbounded', sans-serif", fontWeight: 800,
                  fontSize: "2.4rem", color: p.highlight ? "#1fcc7a" : "#e8edf5",
                  letterSpacing: "-0.03em", lineHeight: 1, marginBottom: "0.4rem",
                }}>{p.price}</div>
                <p style={{ color: "#5a6a80", fontSize: "0.8rem", marginBottom: "1.75rem" }}>{p.per}</p>
                <button onClick={() => navigate("/map")} className="glow-btn" style={{
                  width: "100%", padding: "12px", borderRadius: "10px",
                  background: p.highlight ? "#1fcc7a" : "transparent",
                  border: p.highlight ? "none" : "1px solid #1a2236",
                  color: p.highlight ? "#06090f" : "#8a9ab5",
                  fontWeight: 700, fontSize: "0.9rem", cursor: "pointer",
                  fontFamily: "'Syne', sans-serif",
                }}>
                  Pradėti
                </button>
              </div>
            ))}
          </div>
          <p style={{ textAlign: "center", marginTop: "2rem", color: "#3a4a5c", fontSize: "0.8rem" }}>
            Saugus mokėjimas per Stripe · Visi pagrindiniai mokėjimo metodai
          </p>
        </div>
      </section>

      {/* ======== FAQ ======== */}
      <section style={{ padding: "7rem clamp(1rem, 5vw, 3rem)", background: "#08111f", borderTop: "1px solid #1a2236" }}>
        <div style={{ maxWidth: "680px", margin: "0 auto" }}>
          <div style={{ textAlign: "center", marginBottom: "3.5rem" }}>
            <span style={{
              fontSize: "0.75rem", fontWeight: 700, letterSpacing: "0.15em",
              textTransform: "uppercase", color: "#1fcc7a", display: "block", marginBottom: "1rem"
            }}>FAQ</span>
            <h2 style={{
              fontFamily: "'Syne', sans-serif", fontWeight: 800,
              fontSize: "clamp(1.8rem, 4vw, 2.5rem)", color: "#e8edf5", letterSpacing: "-0.02em"
            }}>Dažniausiai užduodami klausimai</h2>
          </div>
          <div style={{ borderTop: "1px solid #1a2236" }}>
            {FAQ.map((f, i) => <FaqItem key={i} {...f} />)}
          </div>
        </div>
      </section>

      {/* ======== FINAL CTA ======== */}
      <section style={{ padding: "8rem clamp(1rem, 5vw, 3rem)", position: "relative", overflow: "hidden" }}>
        <div style={{
          position: "absolute", top: "50%", left: "50%", transform: "translate(-50%, -50%)",
          width: "600px", height: "300px", maxWidth: "100vw",
          background: "radial-gradient(ellipse, #1fcc7a18 0%, transparent 70%)",
          pointerEvents: "none",
        }} />
        <div style={{ maxWidth: "700px", margin: "0 auto", textAlign: "center", position: "relative" }}>
          <h2 style={{
            fontFamily: "'Unbounded', sans-serif", fontWeight: 900,
            fontSize: "clamp(2rem, 5vw, 4rem)", letterSpacing: "-0.03em",
            lineHeight: 1.1, marginBottom: "1.5rem",
          }}>
            <span style={{ color: "#e8edf5" }}>PRADĖKITE</span><br />
            <span className="shimmer-text">ŠIANDIEN</span>
          </h2>
          <p style={{ color: "#5a6a80", fontSize: "1rem", marginBottom: "2.5rem", lineHeight: 1.7 }}>
            Pirmą ataskaitą galite gauti per 60 sekundžių. Registracija nemokama.
          </p>
          <button onClick={() => navigate("/map")} className="glow-btn" style={{
            background: "#1fcc7a", color: "#06090f",
            padding: "18px 48px", borderRadius: "14px", cursor: "pointer",
            fontSize: "1.05rem", fontWeight: 800, border: "none",
            fontFamily: "'Syne', sans-serif", letterSpacing: "-0.01em",
          }}>
            Pradėti nemokamai →
          </button>
        </div>
      </section>

      {/* ======== FOOTER ======== */}
      <footer style={{
        borderTop: "1px solid #1a2236",
        padding: "2.5rem clamp(1rem, 5vw, 3rem)",
        display: "flex", alignItems: "center", justifyContent: "space-between",
        flexWrap: "wrap", gap: "1rem",
        background: "#06090f",
      }}>
        <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
          <div style={{ color: "#1fcc7a" }}><IconLayers /></div>
          <span style={{ fontFamily: "'Syne', sans-serif", fontWeight: 800, fontSize: "1rem" }}>
            Žemė<span style={{ color: "#1fcc7a" }}>Pro</span>
          </span>
        </div>
        <p style={{ color: "#2a3a52", fontSize: "0.8rem" }}>
          Duomenys: Geoportal.lt · Registrų centras · VŽT
        </p>
        <p style={{ color: "#2a3a52", fontSize: "0.8rem" }}>
          © {new Date().getFullYear()} ŽemėPro
        </p>
      </footer>
    </div>
  );
}
