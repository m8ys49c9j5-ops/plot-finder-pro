  const ref = useRef<HTMLDivElement>(null!);
  const vis = useIntersection(ref, { threshold: 0.1 });
  return (
    <div ref={ref} style={{
      background: "#0b1221",
      border: "1px solid #1a2236",
      borderRadius: "16px",
      padding: "1.5rem",
      transition: "all 0.5s ease",
      opacity: vis ? 1 : 0,
      transform: vis ? "translateY(0)" : "translateY(24px)",
    }}
      onMouseEnter={e => {
        (e.currentTarget as HTMLDivElement).style.borderColor = "#1fcc7a44";
        (e.currentTarget as HTMLDivElement).style.background = "#0d1728";
      }}
      onMouseLeave={e => {
        (e.currentTarget as HTMLDivElement).style.borderColor = "#1a2236";
        (e.currentTarget as HTMLDivElement).style.background = "#0b1221";
      }}
